import 'package:flutter/material.dart';

void main() {
  runApp(MyApp());
}

class Product {
  String name;
  String category;
  int price;
  String description;
  Color color;

  Product(this.name, this.category, this.price, this.description, this.color);
}

List<Product> products = [
  Product('Чистящий гель', 'Кухня', 350, 'Удаляет жир', Colors.blue),
  Product('Средство для посуды', 'Кухня', 180, 'Густая формула', Colors.green),
  Product('Освежитель воздуха', 'Дом', 220, 'Морской бриз', Colors.orange),
  Product('Пятновыводитель', 'Стирка', 420, 'Удаляет пятна', Colors.red),
  Product('Кондиционер для белья', 'Стирка', 290, 'Аромат лаванды', Colors.purple),
  Product('Универсальный спрей', 'Дом', 310, 'Очищает всё', Colors.teal),
];

class CartItem {
  Product product;
  int count;
  CartItem(this.product, this.count);
}

class MyApp extends StatefulWidget {
  @override
  _MyAppState createState() => _MyAppState();
}

class _MyAppState extends State<MyApp> {
  int _tab = 0;
  List<CartItem> cart = [];

  void addToCart(Product p) {
    setState(() {
      for (var item in cart) {
        if (item.product.name == p.name) {
          item.count++;
          return;
        }
      }
      cart.add(CartItem(p, 1));
    });
  }

  void removeFromCart(CartItem item) {
    setState(() {
      cart.remove(item);
    });
  }

  void changeCount(CartItem item, int delta) {
    setState(() {
      item.count += delta;
      if (item.count <= 0) {
        cart.remove(item);
      }
    });
  }

  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      debugShowCheckedModeBanner: false,
      home: Scaffold(
        appBar: AppBar(
          title: Text('ХимМаркет'),
          actions: [
            if (_tab == 0)
              Stack(
                children: [
                  IconButton(
                    icon: Icon(Icons.shopping_cart),
                    onPressed: () {
                      setState(() => _tab = 1);
                    },
                  ),
                  if (cart.isNotEmpty)
                    Positioned(
                      right: 8,
                      top: 8,
                      child: Container(
                        padding: EdgeInsets.all(2),
                        decoration: BoxDecoration(
                          color: Colors.red,
                          borderRadius: BorderRadius.circular(10),
                        ),
                        constraints: BoxConstraints(
                          minWidth: 16,
                          minHeight: 16,
                        ),
                        child: Text(
                          '${cart.fold(0, (sum, item) => sum + item.count)}',
                          style: TextStyle(color: Colors.white, fontSize: 10),
                          textAlign: TextAlign.center,
                        ),
                      ),
                    ),
                ],
              )
            else
              IconButton(
                icon: Icon(Icons.store),
                onPressed: () {
                  setState(() => _tab = 0);
                },
              ),
          ],
        ),
        body: _tab == 0
            ? CatalogPage(addToCart: addToCart)
            : CartPage(cart: cart, remove: removeFromCart, changeCount: changeCount),
      ),
    );
  }
}

class CatalogPage extends StatelessWidget {
  final Function(Product) addToCart;
  CatalogPage({required this.addToCart});

  @override
  Widget build(BuildContext context) {
    return GridView.count(
      crossAxisCount: 2,
      padding: EdgeInsets.all(8),
      children: products.map((p) {
        return Card(
          child: InkWell(
            onTap: () {
              Navigator.push(
                context,
                MaterialPageRoute(
                  builder: (_) => DetailPage(product: p, addToCart: addToCart),
                ),
              );
            },
            child: Padding(
              padding: EdgeInsets.all(8),
              child: Column(
                mainAxisAlignment: MainAxisAlignment.spaceBetween,
                children: [
                  Expanded(
                    child: Container(
                      width: double.infinity,
                      color: p.color.withOpacity(0.3),
                      child: Center(
                        child: Text('Фото', style: TextStyle(color: p.color)),
                      ),
                    ),
                  ),
                  Text(p.name,
                      textAlign: TextAlign.center,
                      style: TextStyle(fontWeight: FontWeight.bold)),
                  Text('${p.price} руб.', style: TextStyle(color: Colors.green)),
                  ElevatedButton(
                    onPressed: () => addToCart(p),
                    child: Text('В корзину'),
                  ),
                ],
              ),
            ),
          ),
        );
      }).toList(),
    );
  }
}

class DetailPage extends StatelessWidget {
  final Product product;
  final Function(Product) addToCart;
  DetailPage({required this.product, required this.addToCart});

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(title: Text(product.name)),
      body: Padding(
        padding: EdgeInsets.all(16),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            Container(
              height: 200,
              width: double.infinity,
              color: product.color.withOpacity(0.3),
              child: Center(
                child: Text('Фото товара',
                    style: TextStyle(fontSize: 24, color: product.color)),
              ),
            ),
            SizedBox(height: 16),
            Text(product.name,
                style: TextStyle(fontSize: 24, fontWeight: FontWeight.bold)),
            SizedBox(height: 8),
            Text(product.category, style: TextStyle(color: Colors.grey)),
            SizedBox(height: 8),
            Text('${product.price} руб.',
                style: TextStyle(fontSize: 20, color: Colors.green)),
            SizedBox(height: 16),
            Text(product.description, style: TextStyle(fontSize: 16)),
            Spacer(),
            SizedBox(
              width: double.infinity,
              child: ElevatedButton.icon(
                onPressed: () {
                  addToCart(product);
                  ScaffoldMessenger.of(context).showSnackBar(
                    SnackBar(content: Text('Добавлено в корзину')),
                  );
                },
                icon: Icon(Icons.add_shopping_cart),
                label: Text('В корзину'),
                style: ElevatedButton.styleFrom(
                  padding: EdgeInsets.symmetric(vertical: 12),
                ),
              ),
            ),
          ],
        ),
      ),
    );
  }
}

class CartPage extends StatelessWidget {
  final List<CartItem> cart;
  final Function(CartItem) remove;
  final Function(CartItem, int) changeCount;
  CartPage(
      {required this.cart, required this.remove, required this.changeCount});

  @override
  Widget build(BuildContext context) {
    if (cart.isEmpty) {
      return Center(
        child: Text('Корзина пуста', style: TextStyle(fontSize: 20)),
      );
    }

    int total = 0;
    for (var item in cart) {
      total += item.product.price * item.count;
    }

    return Column(
      children: [
        Expanded(
          child: ListView.builder(
            itemCount: cart.length,
            itemBuilder: (ctx, i) {
              var item = cart[i];
              return Card(
                child: ListTile(
                  leading: Container(
                    width: 50,
                    height: 50,
                    color: item.product.color.withOpacity(0.5),
                    child: Center(child: Text('Ф')),
                  ),
                  title: Text(item.product.name),
                  subtitle: Text('${item.product.price} руб.'),
                  trailing: Row(
                    mainAxisSize: MainAxisSize.min,
                    children: [
                      IconButton(
                          icon: Icon(Icons.remove),
                          onPressed: () => changeCount(item, -1)),
                      Text('${item.count}'),
                      IconButton(
                          icon: Icon(Icons.add),
                          onPressed: () => changeCount(item, 1)),
                      IconButton(
                          icon: Icon(Icons.delete, color: Colors.red),
                          onPressed: () => remove(item)),
                    ],
                  ),
                ),
              );
            },
          ),
        ),
        Container(
          padding: EdgeInsets.all(16),
          color: Colors.grey[200],
          child: Row(
            mainAxisAlignment: MainAxisAlignment.spaceBetween,
            children: [
              Text('Итого: $total руб.',
                  style: TextStyle(fontSize: 18, fontWeight: FontWeight.bold)),
              ElevatedButton(
                onPressed: () {
                  showDialog(
                    context: context,
                    builder: (_) => AlertDialog(
                      title: Text('Заказ оформлен'),
                      content: Text('Спасибо за покупку!'),
                      actions: [
                        TextButton(
                            onPressed: () => Navigator.pop(context),
                            child: Text('OK'))
                      ],
                    ),
                  );
                },
                child: Text('Оформить'),
              ),
            ],
          ),
        ),
      ],
    );
  }
}
